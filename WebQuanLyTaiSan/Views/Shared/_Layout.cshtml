<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Tài Sản</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* Tùy chỉnh nhẹ để giao diện chuyên nghiệp hơn */
        body {
            background-color: #f8f9fc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .navbar {
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 120, 0.15);
            background: #ffffff !important;
        }

        .navbar-brand {
            font-weight: 700;
            color: #4e73df !important;
            letter-spacing: 1px;
        }

        .nav-link {
            font-weight: 500;
            color: #4e73df !important;
            margin: 0 5px;
            transition: all 0.3s;
        }

            .nav-link:hover {
                color: #224abe !important;
                transform: translateY(-2px);
            }

            .nav-link i {
                margin-right: 5px;
                opacity: 0.8;
            }

        .dropdown-menu {
            border: none;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            border-radius: 0.5rem;
        }

        footer {
            background: white;
            padding: 20px 0;
        }

        .container main {
            padding-top: 20px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-laptop-code me-2"></i>ASSET MANAGER
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fa fa-home"></i>Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Computers" asp-action="Index">
                                <i class="fa fa-desktop"></i>Máy Tính
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Components" asp-action="Index">
                                <i class="fa fa-microchip"></i>Linh Kiện
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="MaintenanceLogs" asp-action="Index">
                                <i class="fa fa-history"></i>Nhật Ký
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="cfgDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fa fa-cogs"></i>Cấu Hình
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index"><i class="fas fa-tags me-2"></i>Phân loại</a></li>
                                <li><a class="dropdown-item" asp-controller="Departments" asp-action="Index"><i class="fa fa-building me-2"></i>Phòng ban</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4 mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted shadow-sm mt-auto">
        <div class="container text-center">
            &copy; 2026 - <b>Nhóm 7</b> - Hệ Thống Quản Lý Tài Sản IT
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            // Tối ưu hóa khởi tạo DataTable cho tất cả các bảng
            if ($.fn.DataTable) {
                $('table').not('.no-datatable').each(function() {
                    if (!$.fn.DataTable.isDataTable(this)) {
                        $(this).DataTable({
                            "language": {
                                "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                            },
                            "pageLength": 10,
                            "responsive": true
                        });
                    }
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>