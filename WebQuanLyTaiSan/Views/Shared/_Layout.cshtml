<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Tài Sản</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background-color: #f8f9fc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .navbar {
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 120, 0.1);
            background: #ffffff !important;
            padding: 0.8rem 1rem;
        }

        .navbar-brand {
            font-weight: 800;
            color: #4e73df !important;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .nav-link {
            font-weight: 600;
            color: #5a5c69 !important;
            padding: 0.5rem 1rem !important;
            transition: all 0.2s;
        }

            .nav-link:hover {
                color: #4e73df !important;
                background-color: #f8f9fc;
                border-radius: 0.35rem;
            }

            .nav-link i {
                width: 20px;
                text-align: center;
                margin-right: 8px;
            }

        /* Highlight trang hiện tại */
        .nav-item.active .nav-link {
            color: #4e73df !important;
            background-color: #eaecf4;
            border-radius: 0.35rem;
        }

        .dropdown-menu {
            border: none;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1);
            border-radius: 0.5rem;
            padding: 0.5rem;
        }

        .dropdown-item {
            padding: 0.6rem 1rem;
            border-radius: 0.3rem;
            font-weight: 500;
        }

            .dropdown-item:hover {
                background-color: #f8f9fc;
                color: #4e73df;
            }

        footer {
            background: white;
            padding: 1.5rem 0;
            margin-top: auto;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-shield-alt me-2 text-primary"></i>ASSET PRO
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fa fa-chart-line"></i>Tổng quan
                            </a>
                        </li>

                        @* Gộp Máy tính và Linh kiện vào đây *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="assetDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fa fa-boxes"></i>Kho Tài Sản
                            </a>
                            <ul class="dropdown-menu shadow border-0">
                                <li>
                                    <a class="dropdown-item" asp-controller="Computers" asp-action="Index">
                                        <i class="fa fa-desktop me-2 text-primary"></i>Danh sách Máy Tính
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Components" asp-action="Index">
                                        <i class="fa fa-microchip me-2 text-success"></i>Quản lý Linh Kiện
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Categories" asp-action="Index">
                                        <i class="fas fa-tags me-2 text-warning"></i>Phân loại danh mục
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="MaintenanceLogs" asp-action="Index">
                                <i class="fa fa-wrench"></i>Bảo trì & Sửa chữa
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="cfgDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fa fa-cog"></i>Hệ Thống
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li><a class="dropdown-item" asp-controller="Departments" asp-action="Index"><i class="fa fa-building me-2 text-info"></i>Cơ cấu Phòng ban</a></li>
                                <li><a class="dropdown-item" href="#"><i class="fa fa-users me-2 text-secondary"></i>Người dùng</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4 mt-3">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted shadow-sm mt-auto">
        <div class="container text-center">
            <small>&copy; 2026 - <b>Nhóm 7</b> - Hệ Thống Quản Lý Tài Sản EPU</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            // Tự động thêm class active cho link đang mở
            var currentPath = window.location.pathname;
            $('.nav-link').each(function() {
                if($(this).attr('href') === currentPath) {
                    $(this).closest('.nav-item').addClass('active');
                }
            });

            // Khởi tạo DataTable việt hóa
            if ($.fn.DataTable) {
                $('table').not('.no-datatable').each(function() {
                    if (!$.fn.DataTable.isDataTable(this)) {
                        $(this).DataTable({
                            "language": {
                                "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                            },
                            "pageLength": 10,
                            "responsive": true,
                            "dom": '<"d-flex justify-content-between align-items-center mb-3"lf>rt<"d-flex justify-content-between align-items-center mt-3"ip>'
                        });
                    }
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>