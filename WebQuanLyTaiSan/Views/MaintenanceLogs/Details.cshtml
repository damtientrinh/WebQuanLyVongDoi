@model WebQuanLyTaiSan.Models.MaintenanceLog

@{
    ViewData["Title"] = "Chi tiết bảo trì";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="fas fa-file-invoice me-2"></i>Chi Tiết Nhật Ký Sửa Chữa</h4>
                    <span class="badge bg-light text-dark">ID: #@Model.Id</span>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <h6 class="text-muted text-uppercase small fw-bold">Thông tin thiết bị</h6>
                            <p class="fs-5 mb-1 text-primary">
                                <i class="fas fa-desktop me-2"></i>@Model.Computer?.Name
                            </p>
                            <p class="text-muted">Mã tài sản: <span class="badge bg-secondary">@Model.Computer?.AssetCode</span></p>
                        </div>
                        <div class="col-sm-6 text-sm-end">
                            <h6 class="text-muted text-uppercase small fw-bold">Thời gian & Chi phí</h6>
                            <p class="fs-5 mb-1"><i class="far fa-calendar-check me-2"></i>@Model.RepairDate.ToString("dd/MM/yyyy")</p>
                            <p class="text-danger fw-bold fs-4">@Model.Cost.ToString("N0") đ</p>
                        </div>
                    </div>

                    <hr />

                    <div class="mb-4">
                        <h6 class="text-muted text-uppercase small fw-bold mb-3">Nội dung sửa chữa / Bảo trì</h6>
                        <div class="p-3 bg-light rounded border">
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                @Model.Description
                            }
                            else
                            {
                                <span class="text-italic text-muted">Không có mô tả chi tiết.</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="@(string.IsNullOrEmpty(Model.ImageUrl) ? "col-12" : "col-md-7") mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold mb-3">Nội dung sửa chữa / Bảo trì</h6>
                            <div class="p-3 bg-light rounded border h-100">
                                @if (!string.IsNullOrEmpty(Model.Description))
                                {
                                    <div style="white-space: pre-line;">@Model.Description</div>
                                }
                                else
                                {
                                    <span class="text-italic text-muted">Không có mô tả chi tiết.</span>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="col-md-5 mb-3 text-center">
                                <h6 class="text-muted text-uppercase small fw-bold mb-3 text-start">Hình ảnh minh chứng</h6>
                                <div class="p-2 border rounded bg-white shadow-sm h-100 d-flex align-items-center justify-content-center">
                                    <a href="~/images/maintenance/@Model.ImageUrl" target="_blank" title="Bấm để xem ảnh lớn">
                                        <img src="~/images/maintenance/@Model.ImageUrl"
                                             class="img-fluid rounded"
                                             style="max-height: 250px; object-fit: contain;"
                                             alt="Ảnh bảo trì" />
                                    </a>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 border-top pt-3">
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning px-4">
                            <i class="fas fa-edit"></i> Chỉnh sửa
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-list"></i> Quay lại danh sách
                        </a>

                        <button onclick="window.print()" class="btn btn-outline-dark ms-auto">
                            <i class="fas fa-print"></i> In phiếu
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print 
    {
        /* Ẩn các nút bấm và breadcrumb nếu có */
        .btn, .card-header .btn, a, hr + .d-flex

        {
            display: none !important;
        }

        /* Hiển thị tiêu đề in riêng (tùy chọn) */
        .card-header {
            background-color: transparent !important;
            color: black !important;
            border-bottom: 2px solid #333 !important;
        }

        .card {
            border: none !important;
            box-shadow: none !important;
        }

        body {
            background-color: white !important;
        }

        .col-md-5, .col-md-7 {
            width: 100% !important; /* Khi in thì hiện theo chiều dọc cho rõ */
            float: none !important;
        }

        img {
            max-height: 400px !important; /* Khi in cho phép ảnh hiện to hơn một chút */
            page-break-inside: avoid; /* Tránh việc ảnh bị cắt đôi giữa 2 trang */
        }

    }
</style>