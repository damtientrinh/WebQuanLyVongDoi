@model IEnumerable<WebQuanLyTaiSan.Models.MaintenanceLog>

@{
    ViewData["Title"] = "Thùng rác nhật ký bảo trì";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h4 class="text-secondary fw-bold mb-0">
                    <i class="fas fa-trash-restore me-2 text-danger"></i>Thùng rác Nhật ký
                </h4>
                <small class="text-muted">Danh sách các bản ghi đã tạm xóa</small>
            </div>
            <div class="col-md-6 text-md-end">
                <a asp-action="Index" class="btn btn-light rounded-pill px-4 border">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="trashTable">
                <thead class="bg-light text-secondary text-uppercase small fw-bolder">
                    <tr>
                        <th class="ps-4">Ngày xóa</th>
                        <th>Thiết bị</th>
                        <th>Nội dung</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="text-danger fw-bold">@item.DeletedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                                <br /><small class="text-muted">Bởi: @item.DeletedBy</small>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.Computer?.Name</div>
                                <span class="badge bg-light text-dark border">@item.Computer?.AssetCode</span>
                            </td>
                            <td>
                                <div class="text-muted small text-truncate" style="max-width: 250px;" title="@item.Description">
                                    @item.Description
                                </div>
                            </td>
                            <td class="text-center">
                                <form asp-action="Restore" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-success rounded-pill px-3 shadow-sm">
                                        <i class="fas fa-undo me-1"></i> Khôi phục
                                    </button>
                                </form>

                                <form asp-action="DeletePermanently" asp-route-id="@item.Id" method="post" class="d-inline ms-1"
                                      onsubmit="return confirmDelete(event, this)">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                        <i class="fas fa-fire me-1"></i> Xóa vĩnh viễn
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $('#trashTable').DataTable({
                "destroy": true,
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json" },
                "order": [[0, "desc"]]
            });
        });

        // Hàm xác nhận xóa xịn hơn dùng SweetAlert2
        function confirmDelete(event, form) {
            event.preventDefault();
            Swal.fire({
                title: 'Xóa vĩnh viễn?',
                text: "Dữ liệu và hình ảnh đính kèm sẽ mất hoàn toàn!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Đồng ý xóa!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        }
    </script>
}