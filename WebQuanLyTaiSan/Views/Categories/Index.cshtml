@model IEnumerable<WebQuanLyTaiSan.Models.Category>

@{
    ViewData["Title"] = "Phân loại tài sản";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h4 class="text-primary fw-bold mb-0">
                    <i class="fas fa-tags me-2"></i>Danh mục Phân loại
                </h4>
                <small class="text-muted">Quản lý các nhóm thiết bị và linh kiện trong hệ thống</small>
            </div>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="fas fa-plus-circle me-1"></i> Thêm danh mục
            </a>
        </div>
    </div>

    <div class="card-body p-0">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show m-3 border-0 shadow-sm" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-3 border-0 shadow-sm" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="table-responsive">
            <table id="categoryTable" class="table table-hover align-middle mb-0 no-datatable">
                <thead class="bg-light text-secondary text-uppercase small fw-bolder">
                    <tr>
                        <th class="ps-4" style="width: 25%">Tên Danh Mục</th>
                        <th style="width: 30%">Mô tả chi tiết</th>
                        <th class="text-center" style="width: 25%">Thống kê phân bổ</th>
                        <th class="text-center pe-4" style="width: 20%">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="bg-warning-subtle text-warning rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                        <i class="fas fa-folder-open fa-sm"></i>
                                    </div>
                                    <div class="fw-bold text-dark">@item.Name</div>
                                </div>
                            </td>
                            <td>
                                <div class="text-muted small text-wrap" style="max-height: 50px; overflow: hidden;">
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        @item.Description
                                    }
                                    else
                                    {
                                        <em class="opacity-50">Chưa có mô tả cho nhóm này</em>
                                    }
                                </div>
                            </td>
                            <td class="text-center">
                                @{
                                    var compCount = item.Computers?.Count ?? 0;
                                    var partCount = item.Components?.Count ?? 0;
                                }
                                <div class="d-flex justify-content-center gap-2">
                                    <span class="badge rounded-pill @(compCount > 0 ? "bg-primary-subtle text-primary border border-primary-subtle" : "bg-light text-muted border") px-3 py-2" title="Máy tính">
                                        <i class="fas fa-desktop me-1"></i> @compCount
                                    </span>
                                    <span class="badge rounded-pill @(partCount > 0 ? "bg-info-subtle text-info border border-info-subtle" : "bg-light text-muted border") px-3 py-2" title="Linh kiện">
                                        <i class="fas fa-microchip me-1"></i> @partCount
                                    </span>
                                </div>
                                <div class="mt-2">
                                    <small class="text-secondary fw-bold">Tổng tài sản: <span class="text-primary">@item.TotalAssets</span></small>
                                </div>
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group shadow-sm rounded">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white border-end" title="Sửa"><i class="fas fa-edit text-warning"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-white border-end" title="Chi tiết"><i class="fas fa-eye text-info"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-white text-danger" title="Xóa"><i class="fas fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Chống rung lắc thanh cuộn */
    .table-responsive {
        overflow-x: hidden !important;
        padding-bottom: 1px;
    }

    #categoryTable tbody tr {
        transition: all 0.2s ease-in-out;
        border-left: 3px solid transparent;
    }

        #categoryTable tbody tr:hover {
            background-color: #fcfaff !important; /* Màu tím cực nhạt cho danh mục */
            border-left: 3px solid #6610f2; /* Vạch tím đặc trưng của tags */
            cursor: pointer;
        }

    .btn-white {
        background: white;
        border: 1px solid #dee2e6;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }

    /* Palette màu nhạt */
    .bg-warning-subtle {
        background-color: #fff3cd !important;
    }

    .bg-primary-subtle {
        background-color: #cfe2ff !important;
    }

    .bg-info-subtle {
        background-color: #cff4fc !important;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#categoryTable').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                },
                "pageLength": 10,
                "columnDefs": [
                    { "orderable": false, "targets": 3 }
                ],
                "dom": '<"d-flex justify-content-between align-items-center p-3"lf>rt<"d-flex justify-content-between align-items-center p-3"ip>'
            });
        });
    </script>
}