@model IEnumerable<WebQuanLyTaiSan.Models.Category>

@{
    ViewData["Title"] = "Phân loại tài sản";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h4 class="text-primary fw-bold mb-0">
                        <i class="fas fa-tags me-2"></i>Danh mục Phân loại
                    </h4>
                    <p class="text-muted small mb-0">Quản lý và định nghĩa các nhóm tài sản IT trong hệ thống</p>
                </div>
                <div class="col-md-6 text-md-end mt-2 mt-md-0">
                    <button id="btnInDanhSach"  class="btn btn-outline-secondary btn-sm me-2 shadow-none">
                        <i class="fas fa-print me-1"></i> In danh sách
                    </button>
                    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <i class="fas fa-plus-circle me-1"></i> Thêm danh mục
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            @* Alert Messages *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show m-3 border-0 shadow-sm" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show m-3 border-0 shadow-sm" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="table-responsive">
                <table id="categoryTable" class="table table-hover align-middle mb-0 border-0">
                    <thead class="bg-light text-secondary text-uppercase small fw-bolder">
                        <tr>
                            <th class="ps-4 border-0">Tên Danh Mục</th>
                            <th class="border-0">Loại Nhóm</th>
                            <th class="border-0">Mô tả chi tiết</th>
                            <th class="text-center border-0">Thống kê phân bổ</th>
                            <th class="text-center pe-4 border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        @{
                                            var iconClass = item.Group == WebQuanLyTaiSan.Models.CategoryGroup.Device ? "fa-laptop text-primary" :
                                            item.Group == WebQuanLyTaiSan.Models.CategoryGroup.Component ? "fa-microchip text-success" : "fa-keyboard text-info";
                                            var bgClass = item.Group == WebQuanLyTaiSan.Models.CategoryGroup.Device ? "bg-primary-subtle" :
                                            item.Group == WebQuanLyTaiSan.Models.CategoryGroup.Component ? "bg-success-subtle" : "bg-info-subtle";
                                        }
                                        <div class="@bgClass rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="fas @iconClass"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.Name</div>
                                            <small class="text-primary fw-semibold">@item.CategoryCode</small>
                                            <small class="text-muted" style="font-size: 0.75rem;">ID: #@item.Id</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill @(item.Group == WebQuanLyTaiSan.Models.CategoryGroup.Device ? "bg-primary" : item.Group == WebQuanLyTaiSan.Models.CategoryGroup.Component ? "bg-success" : "bg-info") py-2 px-3">
                                        <i class="fas fa-layer-group me-1 small"></i> @item.Group
                                    </span>
                                </td>
                                <td>
                                    <div class="text-muted small text-wrap" style="max-width: 250px;">
                                        @(string.IsNullOrEmpty(item.Description) ? "---" : item.Description)
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="d-inline-flex gap-2">
                                        <div class="stat-box" title="Máy tính">
                                            <span class="text-primary fw-bold">@item.ComputerCount</span>
                                            <i class="fas fa-desktop ms-1 text-muted"></i>
                                        </div>
                                        <div class="stat-box" title="Linh kiện">
                                            <span class="text-success fw-bold">@item.ComponentCount</span>
                                            <i class="fas fa-microchip ms-1 text-muted"></i>
                                        </div>
                                    </div>
                                    <div class="mt-1">
                                        <div class="progress" style="height: 4px; width: 80px; margin: 0 auto;">
                                            @{
                                                int total = item.ComputerCount + item.ComponentCount;
                                                int pcPercent = total == 0 ? 0 : (item.ComputerCount * 100 / total);
                                            }
                                            <div class="progress-bar bg-primary" role="progressbar" style="width: @pcPercent%"></div>
                                            <div class="progress-bar bg-success" role="progressbar" style="width: @(100 - pcPercent)%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm rounded-circle shadow-none" data-bs-toggle="dropdown">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                            <li><a class="dropdown-item py-2" asp-action="Edit" asp-route-id="@item.Id"><i class="fas fa-edit text-warning me-2"></i>Chỉnh sửa</a></li>
                                            <li><a class="dropdown-item py-2" asp-action="Details" asp-route-id="@item.Id"><i class="fas fa-info-circle text-info me-2"></i>Chi tiết</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item py-2 text-danger" asp-action="Delete" asp-route-id="@item.Id"><i class="fas fa-trash me-2"></i>Xóa</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Style mới cho cột thống kê */
    .stat-box {
        background: #f8f9fa;
        border: 1px solid #eee;
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 0.85rem;
    }

    /* Hiệu ứng Hover hàng */
    #categoryTable tbody tr {
        transition: all 0.2s;
        cursor: pointer;
    }

        #categoryTable tbody tr:hover {
            background-color: #f8faff !important;
        }

    /* Dropdown menu hiện đại */
    .dropdown-item:active {
        background-color: #4e73df;
    }

    /* Badge palette */
    .bg-primary-subtle {
        background-color: #eef2ff !important;
        color: #4e73df;
    }

    .bg-success-subtle {
        background-color: #ecfdf5 !important;
        color: #10b981;
    }

    .bg-info-subtle {
        background-color: #f0f9ff !important;
        color: #0ea5e9;
    }
</style>

@section Scripts {
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <script>
        $(document).ready(function () {
            // 1. Hủy thực thể cũ nếu có (để tránh lỗi Reinitialise)
            if ($.fn.DataTable.isDataTable('#categoryTable')) {
                $('#categoryTable').DataTable().destroy();
            }

            // 2. Khởi tạo DataTable với cấu hình Buttons
            var table = $('#categoryTable').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                },
                "dom": '<"d-flex justify-content-between align-items-center p-3"Blf>rt<"d-flex justify-content-between align-items-center p-3"ip>',
                "columnDefs": [
                    { "orderable": false, "targets": [3, 4] }
                ],
                "buttons": [
                    {
                        extend: 'print',
                        className: 'd-none',
                        title: '', // Để trống nếu muốn tự thiết kế tiêu đề trong trang in
                        messageTop: function () {
                            return '<h2 class="text-center my-4">DANH SÁCH DANH MỤC PHÂN LOẠI TÀI SẢN</h2>';
                        },
                        exportOptions: {
                            columns: [0, 1, 2, 3] // Bỏ cột "Thao tác" (cột số 4)
                        },
                        customize: function (win) {
                            // Tùy chỉnh thêm CSS cho trang in nếu cần
                            $(win.document.body).css('font-size', '12pt');
                            $(win.document.body).find('table').addClass('compact').css('font-size', 'inherit');
                        }
                    }
                ]
            });

            // 3. Kích hoạt nút In khi bấm vào nút của Trình
            // Dùng .closest('button') để đảm bảo bắt đúng sự kiện dù bấm vào icon hay chữ
            $('#btnInDanhSach').on('click', function (e) {
                e.preventDefault();
                table.button('.buttons-print').trigger();
            });
        });
    </script>
}