@model WebQuanLyTaiSan.Models.Category

@{
    ViewData["Title"] = "Chi tiết danh mục";
}

<div class="container-fluid shadow-sm p-4 bg-white rounded">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h2 class="text-primary"><i class="fas fa-tags"></i> Danh mục: @Model.Name</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i> Sửa</a>
            <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <p><strong>Mô tả:</strong> @(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả" : Model.Description)</p>
            <p><strong>Tổng số tài sản:</strong> <span class="badge bg-dark">@Model.TotalAssets</span></p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <h5 class="text-primary"><i class="fas fa-desktop"></i> Máy tính (@(Model.Computers?.Count ?? 0))</h5>
            <table class="table table-sm table-hover border mt-2">
                <thead class="table-light">
                    <tr>
                        <th>Mã máy</th>
                        <th>Tên máy</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Computers != null && Model.Computers.Any())
                    {
                        foreach (var comp in Model.Computers)
                        {
                            <tr>
                                <td>@comp.AssetCode</td>
                                <td>@comp.Name</td>
                                <td><a asp-controller="Computers" asp-action="Details" asp-route-id="@comp.Id" class="btn btn-xs btn-outline-primary py-0">Xem</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-3">
                                <i class="fas fa-info-circle"></i> Chưa có máy tính nào trong danh mục này.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <p>
                <strong>Tổng giá trị:</strong>
                <span class="text-danger fw-bold">
                    @((Model.Computers?.Sum(c => c.TotalValue) + Model.Components?.Sum(c => c.Price))?.ToString("N0")) VNĐ
                </span>
            </p>
        </div>

        <div class="col-md-6">
            <h5 class="text-success"><i class="fas fa-microchip"></i> Linh kiện (@(Model.Components?.Count ?? 0))</h5>
            <table class="table table-sm table-hover border mt-2">
                <thead class="table-light">
                    <tr>
                        <th>Tên linh kiện</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Components != null && Model.Components.Any())
                    {
                        foreach (var item in Model.Components)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>
                                    <span class="badge rounded-pill @(item.Status == "Trong kho" ? "bg-info text-dark" : "bg-success")">
                                        @item.Status
                                    </span>
                                </td>
                                <td><a asp-controller="Components" asp-action="Details" asp-route-id="@item.Id" class="btn btn-xs btn-outline-success py-0">Xem</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-3">
                                <i class="fas fa-info-circle"></i> Chưa có máy tính nào trong danh mục này.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>