@model WebQuanLyTaiSan.Models.Category

@{
    ViewData["Title"] = "Thêm danh mục mới";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-folder-plus"></i> Thêm Danh Mục Tài Sản</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        @* Mã danh mục *@
                        <div class="form-group mb-3">
                            <label asp-for="CategoryCode" class="control-label fw-bold"></label>
                            <input asp-for="CategoryCode" class="form-control shadow-sm text-uppercase" placeholder="Ví dụ: LAP, PC, SSD..." />
                            <span asp-validation-for="CategoryCode" class="text-danger"></span>
                        </div>

                        @* 1. Tên danh mục *@
                        <div class="form-group mb-3">
                            <label asp-for="Name" class="control-label fw-bold"></label>
                            <input asp-for="Name" class="form-control shadow-sm" maxlength="100" autofocus placeholder="Ví dụ: Laptop, RAM, Màn hình..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        @* 2. Chọn nhóm tài sản *@
                        <div class="form-group mb-3">
                            <label asp-for="Group" class="control-label fw-bold">Phân loại nhóm</label>
                            <select asp-for="Group" class="form-select shadow-sm border-2 border-primary-subtle"
                                    asp-items="Html.GetEnumSelectList<WebQuanLyTaiSan.Models.CategoryGroup>()">
                            </select>
                            <span asp-validation-for="Group" class="text-danger"></span>
                        </div>

                        @* Icon *@
                        <div class="form-group mb-3">
                            <label asp-for="Icon" class="control-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i id="previewIcon" class="fas fa-icons text-primary"></i>
                                </span>
                                <input asp-for="Icon" id="iconInput" class="form-control shadow-sm" placeholder="Ví dụ: fa-laptop, fa-server..." />
                            </div>
                            <small class="text-muted">Xem tên icon tại FontAwesome 5/6.</small>
                        </div>

                        @* 3. Mô tả *@
                        <div class="form-group mb-4">
                            <label asp-for="Description" class="control-label fw-bold"></label>
                            <small class="text-muted d-block mb-1">Mô tả giúp phân loại tài sản dễ dàng hơn.</small>
                            <textarea asp-for="Description" class="form-control shadow-sm" rows="3" placeholder="Nhập mô tả ngắn về danh mục này..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" id="btnSave" class="btn btn-primary shadow-sm py-2 fw-bold">
                                <span id="spinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                                <i id="iconSave" class="fas fa-save"></i>
                                <span id="btnText">Lưu danh mục</span>
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2">
                                <i class="fas fa-undo"></i> Quay lại danh sách
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            $('form').submit(function (e) {
                if ($(this).valid()) {
                    $('#btnSave').prop('disabled', true);
                    $('#spinner').removeClass('d-none');
                    $('#iconSave').addClass('d-none');
                    $('#btnText').text('Đang xử lý...');
                } 
                else 
                {
                    $('#btnSave').prop('disabled', false);
                    $('#spinner').addClass('d-none');
                    $('#iconSave').removeClass('d-none');
                    $('#btnText').text('Lưu danh mục');
                }
            });
        });

        $('#CategoryCode').on('blur', function() {
            $(this).val($(this).val().toUpperCase());
        });

        $('#iconInput').on('input', function() {
            var iconClass = $(this).val();
            if(iconClass.trim() !== "") {
                $('#previewIcon').attr('class', 'fas ' + iconClass + ' text-primary');
            } else {
                $('#previewIcon').attr('class', 'fas fa-icons text-primary');
            }
        });
    </script>
}