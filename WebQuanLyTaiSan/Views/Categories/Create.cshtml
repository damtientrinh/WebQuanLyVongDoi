@model WebQuanLyTaiSan.Models.Category

@{
    ViewData["Title"] = "Thêm danh mục mới";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-folder-plus"></i> Thêm Danh Mục Tài Sản</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="control-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" maxlength="100" autofocus placeholder="Ví dụ: Laptop, RAM, Màn hình..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Description" class="control-label fw-bold"></label>
                            <small class="text-muted d-block mb-1">Mô tả giúp phân biệt các loại tài sản dễ dàng hơn.</small>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả ngắn về danh mục này..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" id="btnSave" class="btn btn-primary shadow-sm">
                                <span id="spinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                                <i id="iconSave" class="fas fa-save"></i>
                                <span id="btnText">Lưu danh mục</span>
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-undo"></i> Quay lại danh sách
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            $('form').submit(function () {
                // Kiểm tra nếu form hợp lệ (đã qua mặt Validation của ASP.NET)
                if ($(this).valid()) {
                    // Vô hiệu hóa nút để tránh nhấn nhiều lần
                    $('#btnSave').prop('disabled', true);

                    // Hiện spinner, ẩn icon cũ
                    $('#spinner').removeClass('d-none');
                    $('#iconSave').addClass('d-none');

                    // Thay đổi văn bản
                    $('#btnText').text('Đang xử lý...');
                }
            });
        });
    </script>
}