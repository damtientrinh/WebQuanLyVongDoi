@model WebQuanLyTaiSan.Models.Employee

@{
    ViewData["Title"] = "Thêm nhân viên mới";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-white">
            <h5 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-user-plus me-2"></i>Thêm nhân viên mới vào hệ thống
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 border-end">
                        <h6 class="text-muted mb-3 border-bottom pb-2">Thông tin cơ bản</h6>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Họ và tên</label>
                            <input asp-for="FullName" class="form-control" placeholder="Ví dụ: Đàm Tiến Trình" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Email công vụ</label>
                            <input asp-for="Email" class="form-control" placeholder="email@epu.edu.vn" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="09xx xxx xxx" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 ps-md-4">
                        <h6 class="text-muted mb-3 border-bottom pb-2">Thông tin nhân sự</h6>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Mã nhân viên</label>
                            <input asp-for="EmployeeCode" class="form-control" placeholder="Ví dụ: NV001" />
                            <span asp-validation-for="EmployeeCode" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Phòng ban</label>
                            <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId">
                                <option value="">-- Chọn phòng ban --</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mt-4">
                            <div class="form-check form-switch p-3 bg-light rounded border">
                                <input class="form-check-input ms-0 me-2" type="checkbox" asp-for="IsActive" checked>
                                <label class="form-check-label fw-bold" asp-for="IsActive">Đang làm việc</label>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="mt-4" />
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="fas fa-chevron-left me-1"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">
                        <i class="fas fa-save me-1"></i> Lưu hồ sơ nhân viên
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}