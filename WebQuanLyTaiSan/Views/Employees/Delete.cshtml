@model WebQuanLyTaiSan.Models.Employee

@{
    ViewData["Title"] = "Xác nhận xóa nhân viên";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-0 mt-4">
                <div class="card-header bg-danger text-white py-3 text-center">
                    <h5 class="m-0 font-weight-bold text-uppercase">
                        <i class="fas fa-user-slash me-2"></i> Xác nhận xóa nhân viên
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-danger border-start border-4 mb-4">
                        <div class="d-flex">
                            <div class="me-3">
                                <i class="fas fa-exclamation-circle fa-2x"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold">Bạn có chắc chắn muốn xóa nhân viên này?</h6>
                                <p class="mb-0 small">Hành động này sẽ đánh dấu nhân viên là đã xóa. Các dữ liệu liên quan đến tài sản do nhân viên này quản lý có thể bị ảnh hưởng.</p>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-borderless mt-2">
                            <tr>
                                <th class="text-muted w-40">Mã nhân viên:</th>
                                <td class="fw-bold text-primary">@Model.EmployeeCode</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Họ và tên:</th>
                                <td class="fw-bold">@Model.FullName</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Phòng ban:</th>
                                <td>@Model.Department?.Name</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Email:</th>
                                <td>@Model.Email</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Trạng thái:</th>
                                <td>
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success small">Đang làm việc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary small">Tạm nghỉ</span>
                                    }
                                </td>
                            </tr>
                        </table>
                    </div>

                    <hr />

                    <div class="text-center mt-4">
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />
                            <div class="d-grid gap-2 d-md-block">
                                <a asp-action="Index" class="btn btn-outline-secondary px-4 me-md-2">
                                    <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                                </a>
                                <button type="submit" class="btn btn-danger px-4 shadow-sm">
                                    <i class="fas fa-trash-alt me-1"></i> Xác nhận xóa
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="card-footer bg-light text-center py-2">
                    <small class="text-muted">Mã định danh: #@Model.Id | Ngày tạo: @Model.CreatedAt.ToString("dd/MM/yyyy")</small>
                </div>
            </div>
        </div>
    </div>
</div>