@model WebQuanLyTaiSan.Models.Department

@{
    ViewData["Title"] = "Chi tiết phòng ban";
}

<div class="container-fluid shadow-sm p-4 bg-white rounded-3">
    <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
        <div>
            <h2 class="text-primary fw-bold mb-1">
                <i class="fas fa-building me-2"></i>@Model.Name
            </h2>
            <div class="d-flex flex-column gap-1">
                <span class="text-muted"><i class="fas fa-barcode me-2"></i>Mã phòng: <strong>@Model.DeptCode</strong></span>
                <span class="text-muted"><i class="fas fa-map-marker-alt me-2"></i>Vị trí: @(Model.Location ?? "Chưa xác định")</span>
                <span class="text-muted"><i class="fas fa-user-tie me-2"></i>Trưởng phòng: @(Model.ManagerName ?? "Chưa có")</span>
            </div>
        </div>
        <div class="text-end">
            <div class="bg-success-subtle text-success px-3 py-2 rounded-3 border border-success-subtle mb-2">
                <h4 class="fw-bold mb-0">@Model.TotalDepartmentValue.ToString("N0") <small>đ</small></h4>
                <small class="text-uppercase fw-bold" style="font-size: 0.7rem;">Tổng trị giá tài sản</small>
            </div>
            <div class="btn-group shadow-sm">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm px-3">
                    <i class="fas fa-edit me-1"></i> Sửa
                </a>
                <a asp-action="Index" class="btn btn-secondary btn-sm px-3">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold text-secondary mb-0">
                    <i class="fas fa-desktop me-2"></i>Danh sách máy tính thuộc phòng
                </h5>
                <div class="d-flex gap-2">
                    <span class="badge bg-primary rounded-pill d-flex align-items-center px-3">@Model.Computers?.Count thiết bị</span>

                    <button type="button" class="btn btn-outline-success btn-sm rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#assignComputerModal">
                        <i class="fas fa-exchange-alt me-1"></i> Điều chuyển vào
                    </button>

                    <a asp-controller="Computers" asp-action="Create" asp-route-deptId="@Model.Id" class="btn btn-primary btn-sm rounded-pill shadow-sm">
                        <i class="fas fa-plus-circle me-1"></i> Cấp máy mới
                    </a>
                </div>
            </div>


            <div class="table-responsive">
                <table class="table table-hover border align-middle" id="tableComputersInDept">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-3">Mã tài sản</th>
                            <th>Tên máy tính</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Linh kiện</th>
                            <th class="text-end">Trị giá máy</th>
                            <th class="text-center pe-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Computers != null && Model.Computers.Any())
                        {
                            foreach (var computer in Model.Computers)
                            {
                                <tr>
                                    <td class="ps-3"><span class="badge bg-dark">@computer.AssetCode</span></td>
                                    <td class="fw-bold">@computer.Name</td>
                                    <td>
                                        @* Logic hiển thị màu badge theo trạng thái *@
                                        @{
                                            var statusClass = computer.Status == "Đang dùng" ? "bg-success" :
                                            computer.Status == "Hỏng" ? "bg-danger" : "bg-warning text-dark";
                                        }
                                        <span class="badge @statusClass">@computer.Status</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="text-primary fw-bold">
                                            <i class="fas fa-microchip me-1 text-muted"></i> @(computer.Components?.Count ?? 0)
                                        </span>
                                    </td>
                                    <td class="text-end fw-bold text-dark">
                                        @computer.TotalValue.ToString("N0") <small class="text-muted">đ</small>
                                    </td>
                                    <td class="text-center pe-3">
                                        <a asp-controller="Computers" asp-action="Details" asp-route-id="@computer.Id"
                                           class="btn btn-sm btn-outline-info rounded-pill px-3">
                                            Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-12 mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
            <span class="text-muted small italic">
                <i class="fas fa-info-circle me-1"></i> Mã hệ thống: #@Model.Id
            </span>
            <span class="text-muted small">
                <i class="fas fa-history me-1"></i> Lần cuối cập nhật:
                <span class="text-dark fw-bold">@Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                bởi <span class="badge bg-secondary">@Model.UpdatedBy</span>
            </span>
        </div>
    </div>
</div>

<div class="modal fade" id="assignComputerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-mitten me-2"></i>Tiếp nhận máy tính</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Computers" asp-action="AssignToDepartment" method="post">
                <div class="modal-body py-4">
                    <input type="hidden" name="deptId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Chọn máy tính đang rảnh:</label>
                        <select name="computerId" class="form-select shadow-sm" asp-items="ViewBag.AvailableComputers">
                            <option value="">-- Chọn máy tính từ kho --</option>
                        </select>
                        <div class="form-text mt-2 italic">
                            <i class="fas fa-info-circle me-1"></i> Chỉ hiển thị máy tính chưa thuộc phòng ban nào hoặc đang trong kho.
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success px-4">Xác nhận chuyển</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tableComputersInDept').DataTable({
                "destroy": true,
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                },
                "pageLength": 5, 
                "order": [[0, "asc"]],
                "dom": '<"d-flex justify-content-between small text-muted"f>rtip'
            });
        });
    </script>
}