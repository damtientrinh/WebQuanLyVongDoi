@model WebQuanLyTaiSan.Models.Department

@{
    ViewData["Title"] = "Chi tiết phòng ban";
}

<div class="container-fluid shadow-sm p-4 bg-white rounded">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <div>
            <h2 class="text-primary mb-0"><i class="fas fa-building"></i> @Model.Name</h2>
            <small class="text-muted"><i class="fas fa-map-marker-alt"></i> Vị trí: @(Model.Location ?? "Chưa xác định")</small>
        </div>
        <div>
            <h4 class="text-success mb-0">Tổng trị giá: @Model.TotalDepartmentValue.ToString("N0") đ</h4>
            <div class="text-end mt-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">Sửa</a>
                <a asp-action="Index" class="btn btn-secondary btn-sm">Quay lại</a>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <h5 class="mb-3 text-secondary"><i class="fas fa-list"></i> Danh sách máy tính thuộc phòng</h5>

            <table class="table table-hover border" id="tableComputersInDept">
                <thead class="table-light">
                    <tr>
                        <th>Mã máy</th>
                        <th>Tên máy</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Số linh kiện</th>
                        <th class="text-end">Giá trị máy</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Computers != null && Model.Computers.Any())
                    {
                        foreach (var computer in Model.Computers)
                        {
                            <tr>
                                <td><span class="badge bg-dark">@computer.AssetCode</span></td>
                                <td>@computer.Name</td>
                                <td>
                                    <span class="badge @(computer.Status == "Đang dùng" ? "bg-success" : "bg-warning text-dark")">
                                        @computer.Status
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-secondary">
                                        @(computer.Components?.Count ?? 0) thiết bị
                                    </span>
                                </td>
                                <td class="text-end fw-bold">@computer.TotalValue.ToString("N0") đ</td>
                                <td class="text-center">
                                    <a asp-controller="Computers" asp-action="Details" asp-route-id="@computer.Id" class="btn btn-sm btn-outline-info">Xem chi tiết</a>
                                </td>
                            </tr>
                        }
                    }
                    @* else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="fas fa-info-circle"></i> Phòng ban này hiện chưa có máy tính nào được bàn giao.
                            </td>
                        </tr>
                    } *@
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tableComputersInDept').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Vietnamese.json"
                },
                "pageLength": 10,
                "order": [[0, "asc"]] // Sắp xếp theo mã máy
            });
        });
    </script>
}