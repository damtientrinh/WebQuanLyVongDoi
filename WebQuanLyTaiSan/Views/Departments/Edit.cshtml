@model WebQuanLyTaiSan.Models.Department

@{
    ViewData["Title"] = "Chỉnh sửa phòng ban";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h4 class="mb-0"><i class="fas fa-edit"></i> Cập Nhật Phòng Ban</h4>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <small class="text-muted">Đang chỉnh sửa cho:</small>
                        <h5 class="text-primary">@Model.Name</h5>
                    </div>
                    <hr />

                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="control-label fw-bold mb-1"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-building text-primary"></i></span>
                                <input asp-for="Name" class="form-control" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Location" class="control-label fw-bold mb-1"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-map-marker-alt text-danger"></i></span>
                                <input asp-for="Location" class="form-control" />
                            </div>
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2 border-top pt-3">
                            <button type="submit" class="btn btn-warning px-4 shadow-sm fw-bold">
                                <i class="fas fa-save"></i> Cập nhật ngay
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-undo"></i> Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            @if (Model.Computers?.Count > 0)
            {
                <div class="mt-3 alert alert-info">
                    <i class="fas fa-info-circle"></i> Lưu ý: Phòng ban này hiện đang quản lý <strong>@Model.Computers.Count</strong> máy tính. Việc đổi tên sẽ cập nhật đồng bộ cho tất cả thiết bị liên quan.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}