@model IEnumerable<WebQuanLyTaiSan.Models.Department>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h4 class="text-danger fw-bold mb-0">
            <i class="fas fa-trash-alt me-2"></i>Thùng rác Phòng ban
        </h4>
        <a asp-action="Index" class="btn btn-secondary rounded-pill px-4">
            <i class="fas fa-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-secondary small fw-bolder">
                <tr>
                    <th class="ps-4">Tên Phòng Ban</th>
                    <th>Ngày xóa</th>
                    <th>Người xóa</th>
                    <th class="text-center pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.Name</td>
                        <td>@item.DeletedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><span class="badge bg-light text-dark border">@item.DeletedBy</span></td>
                        <td class="text-center pe-4">
                            <form asp-action="Restore" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">
                                    <i class="fas fa-undo me-1"></i> Khôi phục
                                </button>
                            </form>
                            <form asp-action="HardDelete" asp-route-id="@item.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa vĩnh viễn? Thao tác này không thể hoàn tác!')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="fas fa-times-circle me-1"></i> Xóa hẳn
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>