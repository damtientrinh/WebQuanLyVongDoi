@model WebQuanLyTaiSan.Models.Department

@{
    ViewData["Title"] = "Thêm mới phòng ban";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-plus-circle"></i> Thêm Mới Phòng Ban</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" id="createDepartmentForm" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label asp-for="DeptCode" class="control-label fw-bold mb-1">Mã phòng ban</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-barcode text-primary"></i></span>
                                <input asp-for="DeptCode" class="form-control" placeholder="Ví dụ: P001, IT_DEPT..." />
                            </div>
                            <span asp-validation-for="DeptCode" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="control-label fw-bold mb-1">Tên phòng ban</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-building text-primary"></i></span>
                                <input asp-for="Name" class="form-control" placeholder="Ví dụ: Phòng Kế toán..." />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ManagerName" class="control-label fw-bold mb-1">Trưởng phòng</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-user-tie text-primary"></i></span>
                                <input asp-for="ManagerName" class="form-control" placeholder="Tên trưởng phòng..." />
                            </div>
                            <span asp-validation-for="ManagerName" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Location" class="control-label fw-bold mb-1">Vị trí</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-map-marker-alt text-danger"></i></span>
                                <input asp-for="Location" class="form-control" placeholder="Ví dụ: Tầng 3..." />
                            </div>
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                <i class="fas fa-save"></i> Lưu thông tin
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-undo"></i> Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-3 border-0 shadow-sm">
                <i class="fas fa-info-circle me-1"></i> Sau khi tạo phòng ban, bạn có thể bắt đầu gán máy tính vào phòng này trong trang Quản lý máy tính.
            </div>
        </div>
    </div>
</div>


<style>
    /* Hiệu ứng focus cho input group */
    .input-group:focus-within {
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15) !important;
        border-radius: 0.375rem;
    }
    .input-group:focus-within .input-group-text {
        border-color: #86b7fe;
        color: #0d6efd;
    }
    .input-group:focus-within input {
        border-color: #86b7fe;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Thêm hiệu ứng loading khi nhấn nút Lưu
        $(document).ready(function() {
            $('#createDepartmentForm').submit(function() {
                if($(this).valid()) {
                    $(this).find('button[type="submit"]').html('<span class="spinner-border spinner-border-sm me-2"></span> Đang lưu...');
                }
            });
        });
    </script>
}