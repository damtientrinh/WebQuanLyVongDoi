@model IEnumerable<WebQuanLyTaiSan.Models.Component>

@{
    ViewData["Title"] = "Quản lý Linh kiện";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h4 class="text-primary fw-bold mb-0">
                    <i class="fas fa-microchip me-2"></i>Danh mục Linh kiện
                </h4>
                <small class="text-muted">Quản lý RAM, CPU, SSD và các thiết bị rời</small>
            </div>
            <div>
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="fas fa-plus-circle me-1"></i> Thêm linh kiện
                </a>
                <a asp-action="Trash" class="btn btn-light rounded-pill px-4 border ms-2">
                    <i class="fas fa-trash-alt text-danger me-1"></i> Thùng rác
                </a>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table id="componentTable" class="table table-hover align-middle mb-0 no-datatable">
                <thead class="bg-light text-secondary text-uppercase small fw-bolder">
                    <tr>
                        <th class="ps-4">Tên Linh Kiện</th>
                        <th>Số Serial</th>
                        <th class="text-end">Giá Tiền</th>
                        <th class="text-center">Trạng Thái</th>
                        <th>Loại</th>
                        <th>Vị Trí Lắp Đặt</th>
                        <th class="text-center pe-4">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.Name</div>
                                <div class="d-flex gap-2 align-items-center">
                                    <small class="text-muted">ID: #@item.Id</small>
                                    @if (item.WarrantyStatus == "Hết hạn")
                                    {
                                        <span class="badge bg-danger p-1" style="font-size: 0.6rem;">Hết bảo hành</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success p-1" style="font-size: 0.6rem;">Còn BH</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border font-monospace">
                                    <i class="fas fa-barcode me-1 opacity-50"></i>@item.SerialNumber
                                </span>
                            </td>
                            <td class="text-end fw-bold text-success">
                                @item.Price.ToString("N0") <small>đ</small>
                            </td>
                            <td class="text-center">
                                @{
                                    var (bgClass, icon) = item.Status switch
                                    {
                                        "Đang sử dụng" => ("bg-success-subtle text-success border-success", "fa-link"),
                                        "Trong kho" => ("bg-primary-subtle text-primary border-primary", "fa-archive"),
                                        "Hỏng" => ("bg-danger-subtle text-danger border-danger", "fa-exclamation-circle"),
                                        _ => ("bg-secondary-subtle text-secondary border-secondary", "fa-question")
                                    };
                                }
                                <span class="badge rounded-pill border px-3 py-2 @bgClass" style="min-width: 110px;">
                                    <i class="fas @icon me-1"></i> @item.Status
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle">
                                    @item.Category?.Name
                                </span>
                            </td>
                            <td>
                                @if (item.Computer != null)
                                {
                                    <a asp-controller="Computers" asp-action="Details" asp-route-id="@item.ComputerId" class="text-decoration-none">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-dark text-white rounded p-1 me-2" style="font-size: 0.7rem;">
                                                <i class="fas fa-desktop"></i>
                                            </div>
                                            <span class="fw-bold text-primary">@item.Computer.AssetCode</span>
                                        </div>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small italic"><i class="fas fa-minus me-1"></i>Chưa gán máy</span>
                                }
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white border-end"><i class="fas fa-edit text-warning"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-white border-end"><i class="fas fa-eye text-info"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-white"><i class="fas fa-trash text-danger"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Chống rung lắc và tạo hiệu ứng chuyên nghiệp */
    .table-responsive {
        overflow-x: auto !important;
        padding-bottom: 1px;
    }

    #componentTable tbody tr {
        transition: all 0.2s ease-in-out;
        border-left: 3px solid transparent;
    }

        #componentTable tbody tr:hover {
            background-color: #f8f9fc !important;
            border-left: 3px solid #4e73df;
            cursor: pointer;
        }

        #componentTable tbody tr:active {
            background-color: #ebf0ff !important;
            transform: scale(0.99);
        }

    .btn-white {
        background: white;
        border: 1px solid #dee2e6;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }

    /* Bảng màu nhạt cho Badge */
    .bg-success-subtle {
        background-color: #d1e7dd !important;
    }

    .bg-primary-subtle {
        background-color: #cfe2ff !important;
    }

    .bg-danger-subtle {
        background-color: #f8d7da !important;
    }

    .bg-info-subtle {
        background-color: #cff4fc !important;
    }

    .text-info-emphasis {
        color: #055160 !important;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#componentTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                },
                "pageLength": 10,
                "columnDefs": [
                    { "orderable": false, "targets": [5, 6] }
                ],
                "dom": '<"d-flex justify-content-between align-items-center p-3"lf>rt<"d-flex justify-content-between align-items-center p-3"ip>'
            });
        });
    </script>
}