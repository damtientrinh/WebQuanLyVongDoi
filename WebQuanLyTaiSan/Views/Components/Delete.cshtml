@model WebQuanLyTaiSan.Models.Component

@{
    ViewData["Title"] = "Xóa linh kiện";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa linh kiện</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning">
                        <strong>Cảnh báo!</strong> Bạn có chắc chắn muốn xóa linh kiện này khỏi hệ thống? Hành động này không thể hoàn tác.
                    </div>

                    <h5 class="text-secondary border-bottom pb-2 mb-3">Thông tin linh kiện</h5>
                    <dl class="row">
                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Name)</dt>
                        <dd class="col-sm-8 fw-bold text-dark">@Model.Name</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.SerialNumber)</dt>
                        <dd class="col-sm-8"><code>@Model.SerialNumber</code></dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Price)</dt>
                        <dd class="col-sm-8 text-success fw-bold">@Model.Price.ToString("N0") đ</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Status)</dt>
                        <dd class="col-sm-8">
                            @{
                                var statusClass = Model.Status == "Trong kho" ? "bg-info" :
                                (Model.Status == "Đang sử dụng" ? "bg-success" : "bg-danger");
                            }
                            <span class="badge @statusClass px-3 py-2">@Model.Status</span>
                        </dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Category)</dt>
                        <dd class="col-sm-8">@Model.Category?.Name</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Computer)</dt>
                        <dd class="col-sm-8">
                            @(Model.Computer != null ? Model.Computer.AssetCode : "Chưa gán máy")
                        </dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.PurchaseDate)</dt>
                        <dd class="col-sm-8">@Model.PurchaseDate.ToString("dd/MM/yyyy")</dd>
                    </dl>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                        @if (Model.ComputerId != null)
                        {
                            @* Trường hợp linh kiện ĐANG ĐƯỢC LẮP - Khóa nút xóa *@
                            <div class="d-flex align-items-center">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 shadow-sm">
                                    <i class="fas fa-external-link-alt"></i> Đi tới gỡ linh kiện
                                </a>
                                <span class="text-danger ms-3 small">
                                    <i class="fas fa-info-circle"></i> Hãy gỡ linh kiện khỏi máy <strong>@Model.Computer.AssetCode</strong> trước khi xóa.
                                </span>
                            </div>
                        }
                        else
                        {
                            @* Trường hợp linh kiện TRONG KHO - Cho phép xóa *@
                            <form asp-action="Delete">
                                <input type="hidden" asp-for="Id" />
                                <button type="submit" class="btn btn-danger px-4 shadow-sm">
                                    <i class="fas fa-trash-alt"></i> Đồng ý xóa
                                </button>
                            </form>
                        }

                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="fas fa-undo"></i> Hủy bỏ & Quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('form[asp-action="Delete"]').submit(function (e) {
            if (!confirm("Bạn có chắc chắn muốn xác nhận xóa linh kiện này không?")) {
                e.preventDefault();
            }
        });
    });
</script>