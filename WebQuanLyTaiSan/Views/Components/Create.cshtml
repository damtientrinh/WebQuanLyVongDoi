@model WebQuanLyTaiSan.Models.Component

@{
    ViewData["Title"] = "Thêm linh kiện mới";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="fas fa-plus-circle"></i> Thêm Linh Kiện Mới</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Name" class="control-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" placeholder="Ví dụ: RAM Kingston 16GB" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="SerialNumber" class="control-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-barcode"></i></span>
                                <input asp-for="SerialNumber" class="form-control" placeholder="Nhập số Serial..." />
                            </div>
                            <span asp-validation-for="SerialNumber" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Price" class="control-label fw-bold"></label>
                            <div class="input-group">
                                <input asp-for="Price" class="form-control" type="number" step="1000" />
                                <span class="input-group-text" onfocus="this.select()">VNĐ</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="CategoryId" class="control-label fw-bold">Loại linh kiện</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Status" class="control-label fw-bold"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Trong kho">Trong kho</option>
                                <option value="Đang sử dụng">Đang sử dụng</option>
                                <option value="Hỏng">Hỏng</option>
                                <option value="Bảo trì">Bảo trì</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ComputerId" class="control-label fw-bold">Gán cho máy tính</label>
                            <select asp-for="ComputerId" class="form-select" 
                                    asp-items="@(ViewData["ComputerId"] as SelectList)">
                                <option value="">-- Trong kho (Chưa lắp) --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="PurchaseDate" class="control-label fw-bold"></label>
                            <input asp-for="PurchaseDate" class="form-control" type="date" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="WarrantyMonths" class="control-label fw-bold">Bảo hành (tháng)</label>
                            <input asp-for="WarrantyMonths" class="form-control" type="number" value="12" min="0" />
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="form-group mb-3">
                            <label asp-for="Specifications" class="control-label fw-bold"></label>
                            <textarea asp-for="Specifications" class="form-control" rows="2" placeholder="VD: 16GB DDR4 3200MHz..."></textarea>
                        </div>
                    </div>
                </div>

                <hr />
                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">
                        <i class="fas fa-save"></i> Lưu thông tin
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 ms-2">
                        <i class="fas fa-undo"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            // Hàm tự động đổi trạng thái linh kiện dựa trên việc có gán máy hay không
            function updateStatus() {
                var computerId = $('#ComputerId').val(); 

                if (computerId) {
                    $('#Status').val('Đang sử dụng');
                } else {
                    var currentStatus = $('#Status').val();
                    if (currentStatus !== 'Hỏng' && currentStatus !== 'Bảo trì') {
                        $('#Status').val('Trong kho');
                    }
                }
            }

            updateStatus();

            $('#ComputerId').change(function () {
                updateStatus();
            });

            $('#ComputerId, #CategoryId').select2({
                theme: 'bootstrap-5',
                placeholder: '-- Chọn một mục --'
            });
        });
    </script>
}