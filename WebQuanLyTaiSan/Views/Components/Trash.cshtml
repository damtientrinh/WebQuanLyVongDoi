@model IEnumerable<WebQuanLyTaiSan.Models.Component>

@{
    ViewData["Title"] = "Thùng rác Linh kiện";
}

<div class="container-fluid shadow-sm p-4 bg-white rounded">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger"><i class="fas fa-trash-alt"></i> Linh kiện đã xóa</h2>
        <a asp-action="Index" class="btn btn-secondary shadow-sm">
            <i class="fas fa-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="table-responsive">
        <table id="componentTrashTable" class="table table-hover border">
            <thead class="table-secondary">
                <tr>
                    <th>Tên linh kiện</th>
                    <th>Số Serial</th>
                    <th>Loại</th>
                    <th>Phòng ban/Máy cũ</th>
                    <th>Ngày xoá</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Name</td>
                        <td><code>@item.SerialNumber</code></td>
                        <td>@item.Category?.Name</td>
                        <td>
                            @if (item.Computer != null)
                            {
                                <span class="badge bg-light text-dark border">
                                    <i class="fas fa-desktop"></i> @item.Computer.AssetCode
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small italic">Chưa gán máy</span>
                            }
                        </td>
                        <td>@(item.DeletedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <form asp-action="Restore" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-success shadow-sm">
                                        <i class="fas fa-undo"></i> Khôi phục
                                    </button>
                                </form>

                                <form asp-action="DeletePermanent" asp-route-id="@item.Id" method="post"
                                      onsubmit="return confirm('Xóa vĩnh viễn linh kiện này? Thao tác này không thể hoàn tác!')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm">
                                        <i class="fas fa-times"></i> Xóa hẳn
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            if (!$.fn.DataTable.isDataTable('#componentTrashTable')) {
                $('#componentTrashTable').DataTable({
                    "destroy": true,
                    "language": {
                        "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                    },
                    "pageLength": 10,
                    "order": [[0, "asc"]],
                    "columnDefs": [
                        { "orderable": false, "targets": 4 } // Khóa cột Thao tác
                    ]
                });
            }
        });
    </script>
}