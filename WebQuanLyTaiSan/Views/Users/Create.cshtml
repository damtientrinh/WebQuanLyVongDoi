@model WebQuanLyTaiSan.Models.User

@{
    ViewData["Title"] = "Thêm tài khoản mới";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-white">
            <h5 class="m-0 font-weight-bold text-primary"><i class="fas fa-user-plus me-2"></i>Thêm tài khoản hệ thống</h5>
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 border-end">
                        <h6 class="text-muted mb-3">Thông tin đăng nhập</h6>
                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Tên đăng nhập</label>
                            <input asp-for="Username" class="form-control" placeholder="Ví dụ: trinhdt" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Mật khẩu</label>
                            <input name="Password" type="password" class="form-control" placeholder="Nhập mật khẩu ít nhất 6 ký tự" />
                            <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 ps-md-4">
                        <h6 class="text-muted mb-3">Phân quyền & Liên kết</h6>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Vai trò hệ thống</label>
                            <select asp-for="Role" class="form-select">
                                <option value="Staff">Nhân viên (Staff)</option>
                                <option value="Manager">Quản lý (Manager)</option>
                                <option value="Admin">Quản trị viên (Admin)</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Liên kết nhân viên</label>
                            <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.EmployeeId">
                                <option value="">-- Chọn nhân viên sở hữu --</option>
                            </select>
                            <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <div class="form-check form-switch mt-4">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                                <label class="form-check-label fw-bold" asp-for="IsActive">Kích hoạt tài khoản</label>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="mt-4" />
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save me-1"></i> Lưu thông tin
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}