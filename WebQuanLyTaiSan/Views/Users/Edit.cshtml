@model WebQuanLyTaiSan.Models.User

@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
            <h5 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-user-edit me-2"></i>Chỉnh sửa tài khoản: <span class="text-dark">@Model.Username</span>
            </h5>
            <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                @(Model.IsActive ? "Đang hoạt động" : "Đang bị khóa")
            </span>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PasswordHash" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="CreatedBy" />

                <div class="row">
                    <div class="col-md-6 border-end">
                        <h6 class="text-muted mb-3 border-bottom pb-2">Thông tin định danh</h6>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Tên đăng nhập</label>
                            <input asp-for="Username" class="form-control bg-light" readonly />
                            <small class="text-muted">Không thể thay đổi tên đăng nhập.</small>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Email liên hệ</label>
                            <input asp-for="Email" class="form-control" placeholder="example@epu.edu.vn" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Mật khẩu mới</label>
                            <input name="newPassword" type="password" class="form-control" placeholder="Để trống nếu không muốn đổi" />
                            <small class="text-info italic">Chỉ nhập nếu bạn muốn thay đổi mật khẩu cũ.</small>
                        </div>
                    </div>

                    <div class="col-md-6 ps-md-4">
                        <h6 class="text-muted mb-3 border-bottom pb-2">Cấu hình hệ thống</h6>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Vai trò (Role)</label>
                            <select asp-for="Role" class="form-select">
                                <option value="Staff">Staff</option>
                                <option value="Manager">Manager</option>
                                <option value="Admin">Admin</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Nhân viên sở hữu</label>
                            <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.EmployeeId">
                                <option value="">-- Chưa liên kết --</option>
                            </select>
                            <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                        </div>

                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="IsActive">
                                    <label class="form-check-label fw-bold" asp-for="IsActive">Trạng thái hoạt động</label>
                                </div>
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" asp-for="IsDeleted">
                                    <label class="form-check-label text-danger fw-bold" asp-for="IsDeleted">Đánh dấu đã xóa (Soft Delete)</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                    <small class="text-muted">
                        <i class="fas fa-clock"></i> Tạo ngày: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </small>
                    <div>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 me-2">
                            <i class="fas fa-undo me-1"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fas fa-save me-1"></i> Cập nhật ngay
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}