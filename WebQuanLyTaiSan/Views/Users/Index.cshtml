@model IEnumerable<WebQuanLyTaiSan.Models.User>

@{
    ViewData["Title"] = "Danh sách tài khoản";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
        <h5 class="m-0 font-weight-bold text-primary"><i class="fas fa-users-cog me-2"></i>Quản lý tài khoản hệ thống</h5>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="fas fa-plus me-1"></i> Thêm tài khoản mới
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="userTable">
                <thead class="table-light">
                    <tr>
                        <th>Người dùng</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th class="text-center">Trạng thái</th>
                        <th>Nhân viên liên kết</th>
                        <th>Ngày tạo</th>
                        <th class="text-center no-sort">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Username</strong>
                            </td>
                            <td>@item.Email</td>
                            <td>
                                <span class="badge @(item.Role == "Admin" ? "bg-danger" : "bg-info") text-white">
                                    @item.Role
                                </span>
                            </td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge rounded-pill bg-success"><i class="fas fa-check-circle me-1"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-secondary"><i class="fas fa-times-circle me-1"></i>Locked</span>
                                }
                            </td>
                            <td>
                                <small class="text-muted">[@item.Employee?.EmployeeCode]</small><br />
                                <span>@item.Employee?.FullName</span>
                            </td>
                            <td>
                                @(item.CreatedAt.ToString("dd/MM/yyyy"))
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm" title="Chi tiết">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Nếu Layout của Trình chưa tự chạy DataTable cho table này
            if (!$.fn.DataTable.isDataTable('#userTable')) {
                $('#userTable').DataTable({
                    "language": {
                        "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                    },
                    "columnDefs": [{ "orderable": false, "targets": "no-sort" }]
                });
            }
        });
    </script>
}