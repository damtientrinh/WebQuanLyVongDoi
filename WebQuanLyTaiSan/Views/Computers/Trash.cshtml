@model IEnumerable<WebQuanLyTaiSan.Models.Computer>

@{
    ViewData["Title"] = "Thùng rác máy tính";
}

<div class="container-fluid shadow-sm p-4 bg-white rounded">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger"><i class="fas fa-trash-alt"></i> Danh sách máy tính đã xóa</h2>
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
    </div>

    <table id="trashTable" class="table table-hover border no-datatable">
        <thead class="table-secondary">
            <tr>
                <th>Mã tài sản</th>
                <th>Tên máy</th>
                <th>Phòng ban cũ</th>
                <th>Ngày xóa</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="badge bg-dark">@item.AssetCode</span></td>
                    <td>@item.Name</td>
                    <td>@item.Department?.Name</td>
                    @* <td class="text-muted">@item.DeletedAt?.ToString("dd/MM/yyyy HH:mm")</td> *@
                    <td class="text-center">
                        <form asp-action="Restore" asp-route-id="@item.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-success shadow-sm">
                                <i class="fas fa-undo"></i> Khôi phục
                            </button>
                        </form>

                        <a asp-action="DeletePermanent" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-danger ms-1"
                           onclick="return confirm('Cảnh báo: Hành động này không thể hoàn tác. Bạn có chắc muốn xóa vĩnh viễn?')">
                            <i class="fas fa-times"></i> Xóa vĩnh viễn
                        </a>
                    </td>
                </tr>
            }
            @* @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center py-5 text-muted">
                        <i class="fas fa-inbox fa-3x mb-3"></i>
                        <p>Thùng rác đang trống rỗng!</p>
                    </td>
                </tr>
            } *@
        </tbody>
    </table>
</div>


@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#trashTable').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                },
                "pageLength": 10,
                "order": [[0, "desc"]], // Sắp xếp theo mã máy
                "columnDefs": [
                    { "orderable": false, "targets": 3 } // Khóa sắp xếp ở cột Thao tác
                ]
            });
        });
    </script>
}