@model IEnumerable<WebQuanLyTaiSan.Models.Computer>

@{
    ViewData["Title"] = "Thùng rác máy tính";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white py-3 border-0">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0 text-danger fw-bold">
                        <i class="fas fa-trash-alt me-2"></i>Thùng Rác Hệ Thống
                    </h4>
                    <p class="mb-0 text-muted small">Danh sách các thiết bị đã tạm xóa. Bạn có thể khôi phục hoặc xóa vĩnh viễn.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 rounded-pill">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                </a>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table id="trashTable" class="table table-hover align-middle border-0">
                    <thead class="bg-light text-muted small">
                        <tr>
                            <th class="border-0">MÃ TÀI SẢN</th>
                            <th class="border-0">TÊN MÁY TÍNH</th>
                            <th class="border-0">PHÒNG BAN CŨ</th>
                            <th class="border-0">NGÀY XÓA</th>
                            <th class="border-0 text-center">HÀNH ĐỘNG</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="badge bg-secondary opacity-75 fw-normal">@item.AssetCode</span></td>
                                <td class="fw-bold text-dark">@item.Name</td>
                                <td>
                                    <span class="text-muted"><i class="fas fa-building me-1"></i>@(item.Department?.Name ?? "N/A")</span>
                                </td>
                                <td class="text-muted small">
                                    @* Giả sử bạn có thuộc tính DeletedAt trong Model *@
                                    <i class="far fa-calendar-times me-1"></i> 14/04/2026
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <form asp-action="Restore" asp-route-id="@item.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success px-3 rounded-pill me-2">
                                                <i class="fas fa-undo-alt me-1"></i> Khôi phục
                                            </button>
                                        </form>

                                        <a asp-action="DeletePermanent" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger px-3 rounded-pill"
                                           onclick="return confirm('Cảnh báo: Hành động này sẽ xóa dữ liệu vĩnh viễn và không thể khôi phục. Tiếp tục?')">
                                            <i class="fas fa-times-circle me-1"></i> Xóa vĩnh viễn
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="empty-bin-icon mb-3">
                        <i class="fas fa-inbox fa-4x text-light"></i>
                    </div>
                    <h5 class="text-muted">Thùng rác đang trống</h5>
                    <p class="text-muted small">Mọi thứ vẫn sạch sẽ, không có máy tính nào bị xóa tạm thời.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Làm mờ các hàng trong thùng rác để tạo cảm giác dữ liệu cũ */
    #trashTable tbody tr {
        transition: all 0.2s;
        opacity: 0.85;
    }

        #trashTable tbody tr:hover {
            opacity: 1;
            background-color: #fff5f5; /* Màu đỏ cực nhạt khi hover */
        }

    .empty-bin-icon i {
        filter: drop-shadow(0 4px 6px rgba(0,0,0,0.05));
    }

    .table thead th {
        letter-spacing: 0.5px;
        font-weight: 600;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }
</style>