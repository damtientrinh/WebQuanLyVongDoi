@model WebQuanLyTaiSan.Models.Computer

@{
    ViewData["Title"] = "Chi tiết máy tính";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="fas fa-desktop text-primary me-2"></i>@Model.Name
            </h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Danh sách máy</a></li>
                    <li class="breadcrumb-item active">@Model.AssetCode</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning px-4 fw-bold shadow-sm">
                <i class="fas fa-edit me-2"></i>Chỉnh sửa
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="fas fa-arrow-left me-2"></i>Quay lại
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 bg-primary text-white p-3">
                <small class="opacity-75 text-uppercase fw-bold">Mã tài sản</small>
                <h4 class="mb-0 fw-bold">@Model.AssetCode</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 bg-white p-3 border-start border-success border-4">
                <small class="text-muted text-uppercase fw-bold">Tổng giá trị (Linh kiện)</small>
                <h4 class="mb-0 fw-bold text-success">@Model.TotalValue.ToString("N0") <small>đ</small></h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 bg-white p-3 border-start border-danger border-4">
                <small class="text-muted text-uppercase fw-bold">Tổng chi phí vận hành</small>
                <h4 class="mb-0 fw-bold text-danger">@Model.TotalOwnershipCost.ToString("N0") <small>đ</small></h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 bg-white p-3 border-start border-info border-4">
                <small class="text-muted text-uppercase fw-bold">Trạng thái</small>
                <div>
                    @{
                        var statusClass = Model.Status == "Đang dùng" ? "bg-success" :
                        (Model.Status == "Bảo trì" ? "bg-warning text-dark" : "bg-danger");
                    }
                    <span class="badge @statusClass rounded-pill">@Model.Status</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Thông tin quản lý</h5>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Phòng ban phụ trách:</label>
                        <span class="fw-bold text-info"><i class="fas fa-building me-1"></i>@(Model.Department?.Name ?? "Chưa rõ")</span>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Chi phí sửa chữa tích lũy:</label>
                        <span class="fw-bold text-secondary">@Model.MaintenanceLogs?.Sum(x => x.Cost).ToString("N0") VNĐ</span>
                    </div>
                    <hr>
                    <div class="bg-light p-3 rounded-3 mt-3">
                        <p class="small text-muted mb-0 italic">
                            <i class="fas fa-info-circle me-1"></i> "Tổng chi phí vận hành" bao gồm giá mua ban đầu của các linh kiện cộng với tất cả chi phí bảo trì.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-3">
                    <ul class="nav nav-pills" id="computerTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active fw-bold" id="components-tab" data-bs-toggle="pill" data-bs-target="#components" type="button" role="tab">
                                <i class="fas fa-microchip me-2"></i>Linh kiện (@(Model.Components?.Count ?? 0))
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link fw-bold" id="history-tab" data-bs-toggle="pill" data-bs-target="#history" type="button" role="tab">
                                <i class="fas fa-history me-2"></i>Lịch sử bảo trì
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-4">
                    <div class="tab-content" id="computerTabsContent">
                        <div class="tab-pane fade show active" id="components" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead class="text-muted small">
                                        <tr>
                                            <th>TÊN LINH KIỆN</th>
                                            <th>SỐ SERIAL</th>
                                            <th class="text-end">ĐƠN GIÁ</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Components != null && Model.Components.Any())
                                        {
                                            foreach (var comp in Model.Components)
                                            {
                                                <tr>
                                                    <td><span class="fw-bold text-dark">@comp.Name</span></td>
                                                    <td><code class="text-primary bg-light px-2 rounded small">@comp.SerialNumber</code></td>
                                                    <td class="text-end fw-bold text-success">@comp.Price.ToString("N0") đ</td>
                                                    <td class="text-end">
                                                        <a asp-controller="Components" asp-action="Details" asp-route-id="@comp.Id" class="btn btn-sm btn-outline-info rounded-circle">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="history" role="tabpanel">
                            @if (Model.MaintenanceLogs != null && Model.MaintenanceLogs.Any())
                            {
                                <div class="timeline-simple">
                                    @foreach (var log in Model.MaintenanceLogs.OrderByDescending(x => x.RepairDate))
                                    {
                                        <div class="d-flex mb-4">
                                            <div class="flex-shrink-0 text-center" style="width: 80px;">
                                                <div class="fw-bold text-dark">@log.RepairDate.ToString("dd/MM")</div>
                                                <div class="small text-muted">@log.RepairDate.Year</div>
                                            </div>
                                            <div class="flex-grow-1 ms-3 border-start ps-3 pb-2">
                                                <div class="fw-bold text-dark">@log.Description</div>
                                                <div class="text-danger fw-bold small">- @log.Cost.ToString("N0") đ</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5 opacity-50">
                                    <i class="fas fa-clipboard-list fa-3x mb-3"></i>
                                    <p>Chưa có lịch sử bảo trì cho máy này.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .card {
        transition: transform 0.2s;
    }

    .nav-pills .nav-link {
        color: #6c757d;
        border-radius: 8px;
    }

        .nav-pills .nav-link.active {
            background-color: #0d6efd;
            color: white;
        }

    .table thead th {
        border-top: 0;
        border-bottom: 1px solid #eee;
    }

    .border-start {
        border-width: 3px !important;
    }
</style>