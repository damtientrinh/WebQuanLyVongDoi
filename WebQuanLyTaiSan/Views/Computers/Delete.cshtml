@model WebQuanLyTaiSan.Models.Computer

@{
    ViewData["Title"] = "Xóa máy tính";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-gradient-danger py-4 border-0 text-white">
                    <div class="d-flex align-items-center">
                        <div class="header-icon bg-white text-danger rounded-circle me-3 shadow-sm">
                            <i class="fas fa-exclamation-circle fa-lg"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold">Xác Nhận Xóa Tài Sản</h4>
                            <p class="mb-0 text-white-50 small">Hành động này không thể hoàn tác</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="alert alert-soft-danger border-0 p-4 mb-4 rounded-3">
                        <div class="d-flex">
                            <i class="fas fa-radiation-alt fa-2x me-3 text-danger"></i>
                            <div>
                                <h5 class="fw-bold text-danger">Cảnh báo hệ thống!</h5>
                                <p class="mb-0">Bạn đang chuẩn bị xóa vĩnh viễn thiết bị <strong>@Model.AssetCode</strong>. Toàn bộ lịch sử và dữ liệu liên quan sẽ bị loại bỏ khỏi danh mục máy tính.</p>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <h6 class="text-uppercase text-muted fw-bold mb-3 small border-bottom pb-2">Thông tin thiết bị</h6>
                                <div class="mb-2">
                                    <span class="text-muted small">Tên máy:</span>
                                    <div class="fw-bold text-dark">@Model.Name</div>
                                </div>
                                <div class="mb-2">
                                    <span class="text-muted small">Trạng thái hiện tại:</span>
                                    <div>
                                        <span class="badge @(Model.Status == "Đang dùng" ? "bg-success" : "bg-secondary") rounded-pill px-3">
                                            @Model.Status
                                        </span>
                                    </div>
                                </div>
                                <div class="mb-0">
                                    <span class="text-muted small">Phòng ban:</span>
                                    <div class="fw-bold text-dark">@(Model.Department?.Name ?? "Chưa phân bổ")</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <h6 class="text-uppercase text-muted fw-bold mb-3 small border-bottom pb-2">Hệ quả khi xóa</h6>
                                <p class="small mb-2">
                                    <i class="fas fa-coins text-warning me-2"></i>Giá trị tài sản:
                                    <strong class="text-danger">@Model.TotalValue.ToString("N0") đ</strong>
                                </p>

                                @if (Model.Components != null && Model.Components.Any())
                                {
                                    <div class="bg-white p-2 rounded border border-danger-subtle mt-2">
                                        <p class="small text-danger fw-bold mb-1"><i class="fas fa-link me-1"></i> Giải phóng @Model.Components.Count linh kiện:</p>
                                        <ul class="list-unstyled mb-0 ps-2" style="font-size: 0.8rem;">
                                            @foreach (var comp in Model.Components.Take(3))
                                            {
                                                <li class="text-truncate text-muted">• @comp.Name</li>
                                            }
                                            @if (Model.Components.Count > 3)
                                            {
                                                <li class="text-muted italic">...và @(Model.Components.Count - 3) linh kiện khác</li>
                                            }
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <p class="small text-success mb-0"><i class="fas fa-check-circle me-2"></i>Không có linh kiện đi kèm.</p>
                                }
                            </div>
                        </div>

                        <div class="bg-white p-2 rounded border border-danger-subtle mt-2">
                            <p class="small text-danger fw-bold mb-1"><i class="fas fa-link me-1"></i> Giải phóng @Model.Components.Count linh kiện:</p>
                            <div class="mt-2 text-center">
                                <span class="badge bg-warning text-dark" style="font-size: 0.7rem;">
                                    Lưu ý: Hãy gỡ linh kiện trên hệ thống trước nếu muốn tái sử dụng!
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-3 justify-content-center">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill fw-bold border-2">
                            <i class="fas fa-arrow-left me-2"></i>Hủy bỏ
                        </a>

                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger px-4 fw-bold shadow-sm">
                                <i class="fas fa-trash-alt me-2"></i>Xóa (Đưa vào thùng rác)
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-danger {
        background: linear-gradient(45deg, #dc3545 0%, #a71d2a 100%);
    }

    .alert-soft-danger {
        background-color: #f8d7da;
        color: #842029;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Hiệu ứng rung nhẹ cho nút Xóa khi hover để cảnh báo */
    .hover-shake:hover {
        animation: shake 0.5s;
        animation-iteration-count: infinite;
    }

    @@keyframes shake {
        0% {
            transform: translate(1px, 1px) rotate(0deg);
        }

        10% {
            transform: translate(-1px, -2px) rotate(-1deg);
        }

        20% {
            transform: translate(-3px, 0px) rotate(1deg);
        }

        30% {
            transform: translate(3px, 2px) rotate(0deg);
        }

        40% {
            transform: translate(1px, -1px) rotate(1deg);
        }

        50% {
            transform: translate(-1px, 2px) rotate(-1deg);
        }

        100% {
            transform: translate(1px, 1px) rotate(0deg);
        }
    }

    .rounded-4 {
        border-radius: 1.5rem !important;
    }
</style>