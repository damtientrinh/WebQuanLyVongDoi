@model WebQuanLyTaiSan.Models.Computer

@{
    ViewData["Title"] = "Xóa máy tính";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-trash-alt"></i> Xác nhận xóa tài sản</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning border-start border-warning border-4">
                        <h5 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Bạn có chắc chắn?</h5>
                        <p class="mb-0">Hành động này sẽ xóa vĩnh viễn máy tính <strong>@Model.AssetCode</strong> khỏi hệ thống. Các liên kết với linh kiện hiện tại sẽ bị hủy bỏ.</p>
                    </div>

                    <div class="row mt-4">
                        <div class="col-sm-6">
                            <h6 class="text-muted fw-bold text-uppercase small">Thông tin cơ bản</h6>
                            <p><strong>Mã máy:</strong> @Model.AssetCode</p>
                            <p><strong>Tên máy:</strong> @Model.Name</p>
                            <p>
                                <strong>Trạng thái:</strong>
                                <span class="badge @(Model.Status == "Đang dùng" ? "bg-success" : "bg-secondary")">@Model.Status</span>
                            </p>
                        </div>

                        @if (Model.Components != null && Model.Components.Any())
                        {
                            <div class="mt-3 p-2 bg-light rounded border">
                                <p class="small text-muted mb-1"><i class="fas fa-info-circle"></i> Các linh kiện sau sẽ được chuyển về trạng thái <strong>"Trong kho"</strong>:</p>
                                <ul class="mb-0 small">
                                    @foreach (var comp in Model.Components)
                                    {
                                        <li>@comp.Name (S/N: @comp.SerialNumber)</li>
                                    }
                                </ul>
                            </div>
                        }

                        <div class="col-sm-6 border-start">
                            <h6 class="text-muted fw-bold text-uppercase small">Vị trí & Giá trị</h6>
                            <p><strong>Phòng ban:</strong> @Model.Department?.Name</p>
                            <p><strong>Tổng giá trị:</strong> <span class="text-danger fw-bold">@Model.TotalValue.ToString("N0") đ</span></p>
                            <p><strong>Số linh kiện đi kèm:</strong> <span class="badge rounded-pill bg-info text-dark">@(Model.Components?.Count ?? 0)</span></p>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn btn-danger px-4 shadow-sm">
                                <i class="fas fa-check"></i> Xác nhận xóa ngay
                            </button>
                        </form>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="fas fa-times"></i> Hủy bỏ & Quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>